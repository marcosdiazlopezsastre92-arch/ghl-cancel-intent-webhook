PORT=5000

# Tu PIT token de GHL (modo A)
GHL_API_TOKEN=pit-xxxxxxxxxxxxxxxxxxxxxxxx

# API key de Anthropic (clasificador)
# Obténla en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key de OpenAI (transcripción de audios con Whisper).
# Si NO la pones, los audios se ignoran con audio_needs_review.
# Obténla en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cadena aleatoria para proteger el endpoint:
#   openssl rand -hex 32
WEBHOOK_SECRET=cambia-esto-por-una-cadena-aleatoria-larga

# Opcionales
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# WHISPER_MODEL=whisper-1
# CONFIDENCE_THRESHOLD=0.80
# MESSAGES_LOOKBACK=15
